# Copy this to .env and fill in real values — never commit .env

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
CSV_PATH=data/transactions_real.csv
LOG_LEVEL=INFO

# TrueLayer Open Banking (get credentials at truelayer.com)
TRUELAYER_CLIENT_ID=your-client-id
TRUELAYER_CLIENT_SECRET=your-client-secret
TRUELAYER_REDIRECT_URI=spendingcheck://callback
TRUELAYER_SANDBOX=true
